// Accounts is the resolver for the accounts field.
func (r *userResolver) Accounts(ctx context.Context, obj *models.User) ([]*models.Account, error) {
	// Use context for auth validation
	user, err := r.AuthService.GetUserFromContext(ctx)
	if err != nil {
		return nil, err
	}

	// Security check: only return accounts if authenticated user same as requested user
	if obj.ID != user.ID {
		return nil, fmt.Errorf("unauthorized access to user %d accounts", obj.ID)
	}

	// Use obj for display - get accounts for this specific user object
	return r.AccountService.GetAccountsByUserID(ctx, obj.ID)
}

