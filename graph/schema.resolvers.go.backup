// Members is the resolver for the members field.
func (r *sharedBudgetResolver) Members(ctx context.Context, obj *models.SharedBudget) ([]*models.SharedBudgetMember, error) {
	// Check if the requesting user has access to this shared budget
	user, err := r.AuthService.GetUserFromContext(ctx)
	if err != nil {
		return nil, err
	}

	// Verify the user is a member of this budget - this will be checked in the repository
	_, err = r.SharedBudgetService.GetSharedBudgetByID(ctx, user.ID, obj.ID)
	if err != nil {
		return nil, err
	}

	// Convert []models.SharedBudgetMember to []*models.SharedBudgetMember
	members := make([]*models.SharedBudgetMember, len(obj.Members))
	for i := range obj.Members {
		members[i] = &obj.Members[i]
	}
	return members, nil
}

