// SharedBudget is the resolver for the sharedBudget field.
func (r *sharedBudgetInvitationResolver) SharedBudget(ctx context.Context, obj *models.SharedBudgetInvitation) (*models.SharedBudget, error) {
	user, err := r.AuthService.GetUserFromContext(ctx)
	if err != nil {
		return nil, err
	}

	// Check if user has access to this invitation
	if obj.InviterID != user.ID && obj.InviteeID != user.ID {
		return nil, fmt.Errorf("unauthorized access to shared budget invitation")
	}

	// Get the shared budget by ID rather than returning the nested object
	if obj.InviterID == user.ID || obj.InviteeID == user.ID {
		// For invitations, we can allow basic budget info even if not yet a member
		return r.SharedBudgetService.GetSharedBudgetByID(ctx, obj.InviterID, obj.SharedBudgetID)
	}
	

