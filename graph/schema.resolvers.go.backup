	}

	// Verify the user is a member of this budget
	_, err = r.SharedBudgetService.GetSharedBudgetByID(ctx, user.ID, obj.ID)
	if err != nil {
		return nil, err
	}

	// Convert []models.SharedBudgetInvitation to []*models.SharedBudgetInvitation
	invitations := make([]*models.SharedBudgetInvitation, len(obj.Invitations))
	for i := range obj.Invitations {
